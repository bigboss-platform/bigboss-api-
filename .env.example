# Application
APP_ENV=local
APP_SECRET_KEY=changeme-local-secret-key-minimum-32-chars
APP_DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://bigboss:bigboss@localhost:5432/bigboss_db

# Test Database
TEST_DATABASE_URL=postgresql+asyncpg://bigboss:bigboss@localhost:5432/bigboss_test_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (MailHog in local)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@bigboss.io

# OTP
OTP_EXPIRE_SECONDS=60
OTP_MAX_ATTEMPTS=3

# Staging-only OTP bypass (never set this in production)
# OTP_TEST_PHONE=+573000000000
# OTP_TEST_CODE=123456
